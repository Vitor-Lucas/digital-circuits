:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5e83574a5280 .scope module, "inversor_tb" "inversor_tb" 2 2;
 .timescale -9 -10;
v0x5e83574b6a00_0 .var "a", 0 0;
v0x5e83574b6aa0_0 .net "b", 0 0, L_0x5e83574b6b70;  1 drivers
